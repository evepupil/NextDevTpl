# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# fumadocs auto-generated
.source/

# dependencies
/node_modules
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/artifacts

# next.js
/.next/
/out/
/.open-next/
/.wrangler/

# production
/build
packages/*/dist/
packages/*/template/
packages/*/catalog.json

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

#ide
.vscode
.omc

# Windows
nul

# deploy artifacts
deploy.tgz
