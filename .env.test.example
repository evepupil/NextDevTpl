# ============================================
# NextDevTpl 测试环境变量模板
# ============================================
# 用法: 复制为 .env.test 并填入真实值。
#   cp .env.test.example .env.test
#
# 安全提示:
# - .env.test 已被 .gitignore 忽略 (.env* 规则)，请勿提交真实凭据。
# - 测试库密码等敏感信息只应存在于本地 .env.test，不要写进本文件。
# - 测试数据库建议使用独立的 Neon 测试分支，切勿指向生产库。

# ============================================
# 应用配置
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# 数据库配置 (Neon 测试分支)
# 注意: WebSocket 事务模式建议使用非 pooler 端点
# ============================================
DATABASE_URL=postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require&channel_binding=require

# ============================================
# Better Auth 配置
# ============================================
BETTER_AUTH_SECRET=replace-with-a-random-test-secret
BETTER_AUTH_URL=http://localhost:3000

# ============================================
# OAuth 配置 (测试环境可使用占位符)
# ============================================
GITHUB_CLIENT_ID=test-github-client-id
GITHUB_CLIENT_SECRET=test-github-client-secret
GOOGLE_CLIENT_ID=test-google-client-id
GOOGLE_CLIENT_SECRET=test-google-client-secret
